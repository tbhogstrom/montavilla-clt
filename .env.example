# Copy to .env and fill in your values

# Neon — dashboard → your project → Connection Details → Connection string
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Resend — resend.com → API Keys
RESEND_API_KEY=re_...

# Email addresses (must match your verified Resend domain)
FROM_EMAIL=noreply@montavillalandtrust.org
ADMIN_EMAIL=info@montavillalandtrust.org
