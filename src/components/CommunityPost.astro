---
interface Props {
  id: string;
  type: 'discussion' | 'update';
  title: string;
  body?: string | null;
  image_url?: string | null;
  display_name: string;
  neighborhood?: string | null;
  created_at: string;
  likes?: number;
}

const { id, type, title, body, image_url, display_name, neighborhood, created_at, likes = 0 } = Astro.props;

const date = new Date(created_at).toLocaleDateString('en-US', {
  month: 'short', day: 'numeric', year: 'numeric',
});
---

<article class={`community-post community-post--${type}`} data-post-id={id}>
  <a href={`/community/${id}`} class="community-post__link">
    {image_url && (
      <div class="community-post__img">
        <img src={image_url} alt={title} loading="lazy" />
      </div>
    )}
    <div class="community-post__body">
      <div class="community-post__meta">
        <span class={`community-post__badge community-post__badge--${type}`}>
          {type === 'update' ? 'Update' : 'Discussion'}
        </span>
        {neighborhood && <span class="community-post__neighborhood">{neighborhood}</span>}
      </div>
      <h3 class="community-post__title">{title}</h3>
      {body && <p class="community-post__text">{body}</p>}
    </div>
  </a>
  <div class="community-post__footer-wrap">
    <footer class="community-post__footer">
      <div class="community-post__byline">
        <span class="community-post__author">{display_name}</span>
        <span class="community-post__date">{date}</span>
      </div>
      <button
        class="like-btn"
        data-post-id={id}
        data-likes={likes}
        aria-label="Like this post"
      >
        <svg class="like-btn__heart" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
        </svg>
        <span class="like-btn__count">{likes}</span>
      </button>
    </footer>
  </div>
</article>

<style>
.community-post {
  background: var(--forest);
  border: 1px solid rgba(122,158,126,0.15);
  border-top: 3px solid transparent;
  transition: border-top-color 0.2s, transform 0.2s;
  display: flex;
  flex-direction: column;
}
.community-post:hover { border-top-color: var(--ochre); transform: translateY(-3px); }
.community-post--update { border-top-color: var(--gold); }

.community-post__link {
  display: flex; flex-direction: column; flex: 1;
  text-decoration: none; color: inherit;
}

.community-post__img img {
  width: 100%; aspect-ratio: 16/9;
  object-fit: cover; display: block;
}

.community-post__body {
  padding: 1.5rem;
  display: flex; flex-direction: column; gap: 0.75rem;
  flex: 1;
}

.community-post__meta {
  display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;
}

.community-post__badge {
  font-family: 'Work Sans', sans-serif;
  font-size: 0.6rem; font-weight: 700; letter-spacing: 0.15em;
  text-transform: uppercase; padding: 0.2rem 0.55rem;
}
.community-post__badge--discussion { background: rgba(122,158,126,0.2); color: var(--sage); }
.community-post__badge--update     { background: rgba(232,168,50,0.15); color: var(--gold); }

.community-post__neighborhood {
  font-size: 0.7rem; color: rgba(122,158,126,0.6);
  font-family: 'Work Sans', sans-serif;
}

.community-post__title {
  font-family: 'Big Shoulders Display', sans-serif;
  font-weight: 700; font-size: 1.2rem; color: var(--cream); line-height: 1.2;
}
.community-post__link:hover .community-post__title { color: var(--gold); }

.community-post__text {
  font-family: 'Crimson Pro', serif; font-size: 1.05rem;
  color: var(--sage); line-height: 1.6;
  display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
}

.community-post__footer-wrap {
  padding: 0 1.5rem 1.25rem;
}

.community-post__footer {
  display: flex; justify-content: space-between; align-items: center;
  padding-top: 0.75rem;
  border-top: 1px solid rgba(122,158,126,0.1);
}

.community-post__byline {
  display: flex; flex-direction: column; gap: 0.15rem;
}

.community-post__author {
  font-size: 0.8rem; font-weight: 600; color: var(--cream);
  font-family: 'Work Sans', sans-serif;
}
.community-post__date {
  font-size: 0.72rem; color: rgba(122,158,126,0.5);
  font-family: 'Work Sans', sans-serif;
}

.like-btn {
  display: flex; align-items: center; gap: 0.35rem;
  background: none; border: 1px solid rgba(122,158,126,0.25);
  color: var(--sage); cursor: pointer;
  padding: 0.35rem 0.65rem;
  font-family: 'Work Sans', sans-serif; font-size: 0.8rem; font-weight: 600;
  transition: all 0.15s;
}
.like-btn:hover { border-color: var(--ochre); color: var(--ochre); }
.like-btn.liked {
  border-color: var(--ochre); color: var(--ochre);
  background: rgba(200,135,42,0.1);
}
.like-btn.liked .like-btn__heart { fill: var(--ochre); stroke: var(--ochre); }
.like-btn__heart { flex-shrink: 0; transition: fill 0.15s, stroke 0.15s; }
</style>
