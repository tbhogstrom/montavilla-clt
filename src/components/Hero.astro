<section class="hero">
  <div class="hero-left">
    <p class="hero-eyebrow">Montavilla Community Land Trust · montavillalandtrust.org</p>
    <h1>
      SAVE<br>
      <em>THIS</em><br>
      LOT.
    </h1>
    <p class="hero-body">
      The property beneath the Montavilla Farmers Market is for sale.
      We're organizing our neighborhood to buy it — and protect it forever —
      through a Community Land Trust.
    </p>
    <div class="hero-btns">
      <a href="#petition" class="btn btn-primary">Become a Founding Member</a>
      <a href="#building" class="btn btn-ghost">See the Vision</a>
    </div>
  </div>
  <div class="hero-right">
    <div class="hero-stats">
      <div class="stat-box featured">
        <span class="num">19</span>
        <span class="label">Years at SE Stark</span>
        <span class="sub">Home since 2007</span>
      </div>
      <div class="stat-box">
        <span class="num">70<span class="unit">+</span></span>
        <span class="label">Local Vendors</span>
        <span class="sub">Farmers, bakers, makers</span>
      </div>
      <div class="stat-box">
        <span class="num">.84</span>
        <span class="label">Acres to Protect</span>
        <span class="sub">Corner lot, fully assembled</span>
      </div>
      <div class="stat-box">
        <span class="num">∞</span>
        <span class="label">Years Protected</span>
        <span class="sub">If we act now</span>
      </div>
    </div>
  </div>
</section>
