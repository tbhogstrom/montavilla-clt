---
---
<div class="sig-bar" id="sig-bar" aria-live="polite">
  <span id="sig-inner"></span>
</div>

<script>
  fetch('/api/count')
    .then(r => r.json())
    .then(({ count, pledgeTotal }) => {
      if (!count || count < 1) return;
      const bar   = document.getElementById('sig-bar');
      const inner = document.getElementById('sig-inner');
      if (!bar || !inner) return;
      const label = count === 1 ? 'Montavilla neighbor has joined' : 'Montavilla neighbors have joined';
      const fmt = (n: number) =>
        new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(n);
      const pledgePart = pledgeTotal > 0
        ? ` &nbsp;·&nbsp; <strong>${fmt(pledgeTotal)}</strong> pledged`
        : '';
      inner.innerHTML = `<strong>${count.toLocaleString()}</strong> ${label} the coalition${pledgePart}`;
      bar.classList.add('sig-bar--visible');
    })
    .catch(() => {/* stay hidden */});
</script>
