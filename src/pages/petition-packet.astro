      <div class="field-line"></div>
    </div>
    <div class="captain-field">
      <label>Street / Block</label>
      <div class="field-line"></div>
    </div>
    <div class="captain-field">
      <label>Date Returned to MCLT</label>
      <div class="field-line"></div>
    </div>
  </div>

  <div class="petition-footer">
    <span>montavillalandtrust.org · info@montavillalandtrust.org · Montavilla Community Land Trust</span>
